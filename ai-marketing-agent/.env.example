# ─── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
MAX_TOKENS=2000
TEMPERATURE=0.7

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=sqlite:///./marketing.db

# ─── App ──────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# ─── Optional: Email Outreach ─────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
